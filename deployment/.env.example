# === Image Docker ===
registry=example.com
image-name=image
tag=latest

# === Django ===
# === Email (SendGrid) ===
emailhost=host.email.com
emailport=000
emailuse-tls=Boolean
emailuser=emailuser
emailpassword=SG.xxxxxxxxxxxxxxxxxxxxxx
defaultfromemail=default@email.com

# === Database (Postgres / Supabase) ===
host=aws-0-xx-xxxx-x.pooler.supabase.com
port=9876
database=postgres
user=postgres.xxxxxxxxxxxxxxxxxxxx
password=CHANGE_ME

# === Django ===
DEBUG=False
SECRET_KEY=django-insecure-CHANGE_ME_use_get_random_secret_key
DJANGO_SETTINGS_MODULE=PATH_TO_SETTINGS_MODULE
ALLOWED_HOSTS=127.0.0.1,localhost

# === Redis / Celery ===
REDIS_URL=redis://default:password@host:port